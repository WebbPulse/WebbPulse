# =============================================================================
# WebbPulse monorepo — React/TypeScript frontend + FastAPI/Python backend
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (frontend/)
# -----------------------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.env
frontend/.env.*
!frontend/.env.example

# -----------------------------------------------------------------------------
# Backend (backend/)
# -----------------------------------------------------------------------------
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/**/*.pyc
backend/venv/
backend/.env
backend/.env.*
!backend/.env.example
backend/htmlcov/
backend/.coverage
backend/.pytest_cache/

# -----------------------------------------------------------------------------
# Terraform (terraform/)
# -----------------------------------------------------------------------------
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/*.tfvars.example

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Editors
# -----------------------------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Secrets / local overrides
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
.envrc
